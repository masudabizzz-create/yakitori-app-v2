# ローカル開発用（テスト Supabase プロジェクトの値を入れる）
# この .env.local は .gitignore に登録済みのため、本番の鍵は絶対に書かないこと
# 本番の鍵は GitHub Secrets（Actions）でのみ管理する

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...（テストプロジェクトの anon key）
VITE_SUPABASE_SERVICE_ROLE_KEY=eyJ...（テストプロジェクトの service_role key）
